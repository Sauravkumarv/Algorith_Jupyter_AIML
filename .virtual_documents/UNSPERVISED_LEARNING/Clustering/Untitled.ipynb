


import seaborn as sns
from sklearn.datasets import make_blobs


X,y=make_blobs(
    n_samples=1000,
    n_features=2,
    centers=4,
    random_state=42
)



# Visualize
sns.scatterplot(x=X[ :,0],y=X[:,1])


