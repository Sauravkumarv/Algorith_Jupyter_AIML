import pandas as pd
from sklearn.svm import SVC
from sklearn import datasets
from sklearn.model_selection import train_test_split




df=datasets.load_iris(as_frame=True).frame
df.head()


df["target"].value_counts()
X=df.drop("target",axis=1)
y=df["target"]



X_train,X_test,y_train,y_test=train_test_split(X,y,test_size=0.3,random_state=42,stratify=y)



from sklearn.preprocessing import StandardScaler


scaler=StandardScaler()
X_train_scaled=scaler.fit_transform(X_train)
y_test_scaled=scaler.transform(X_test)


svc=SVC()
svc.fit(X_train_scaled,y_train)




from sklearn.metrics import f1_score,accuracy_score,classification_report
y_pred=svc.predict(y_test_scaled)
accuracy_score(y_test,y_pred)
print("\n",classification_report(y_test,y_pred))


# Now Applying different Kernal
# rbf (radial basis fix)
svc1=SVC(kernel="rbf")
svc1.fit(X_train_scaled,y_train)
y_pred=svc1.predict(y_test_scaled)
accuracy_score(y_test,y_pred)



# Now Applying different Kernal
svc1=SVC(kernel="poly")
svc1.fit(X_train_scaled,y_train)
y_pred=svc1.predict(y_test_scaled)
accuracy_score(y_test,y_pred)



# Now Applying different Kernal
svc1=SVC(kernel="linear")
svc1.fit(X_train_scaled,y_train)
y_pred=svc1.predict(y_test_scaled)
accuracy_score(y_test,y_pred)



# Now Applying different Kernal
svc1=SVC(kernel="sigmoid")
svc1.fit(X_train_scaled,y_train)
y_pred=svc1.predict(y_test_scaled)
accuracy_score(y_test,y_pred)




